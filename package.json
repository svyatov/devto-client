{
  "name": "devto-client",
  "version": "0.1.0",
  "description": "Typed, zero-dependency client for the dev.to (Forem) v1 API",
  "license": "MIT",
  "author": "Leonid Svyatov <leonid@svyatov.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/svyatov/devto-client.git"
  },
  "keywords": [
    "dev.to",
    "devto",
    "forem",
    "api",
    "client",
    "typescript"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22.12"
  },
  "packageManager": "npm@12.0.1",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "biome check .",
    "test": "vitest run --coverage",
    "compose": "node --experimental-strip-types scripts/compose-spec.ts",
    "generate": "npm run compose && npx -y openapi-typescript@7.13.0 spec/composed.json -o src/generated/types.ts && biome check --write src/generated/types.ts",
    "prepublishOnly": "npm run build && npx publint && npx attw --pack ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
